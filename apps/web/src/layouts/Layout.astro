---
import '../styles/global.css';
import Container from '../components/layout/Container.astro';
import Navigation from '../components/layout/Navigation.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { createTranslator } from '../i18n';
import nav from '../i18n/nav.json';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Colourfully Digital - Creative web development and design" } = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;
const currentLocale = currentPath.split('/')[1] || 'en';
const t = createTranslator(nav, currentLocale);

// Build localized navigation items
const navigationItems = [
  { label: t('home'), href: `/${currentLocale}/` },
  { 
    label: 'Services', // TODO: Add to translations
    href: `/${currentLocale}/services`,
    children: [
      { label: 'Web Development', href: `/${currentLocale}/services/web-development` },
      { label: 'Design', href: `/${currentLocale}/services/design` },
      { label: 'Consulting', href: `/${currentLocale}/services/consulting` }
    ]
  },
  { label: t('about'), href: `/${currentLocale}/about` },
  { label: t('contact'), href: `/${currentLocale}/contact` }
];

// Generate alternate language URLs
const alternateUrls = {
  en: `${Astro.site}en${currentPath.replace(/^\/(en|fr)/, '')}`,
  fr: `${Astro.site}fr${currentPath.replace(/^\/(en|fr)/, '')}`
};
---

<!DOCTYPE html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">

    <!-- Language alternates -->
    <link rel="alternate" href={alternateUrls.en} hreflang="en" />
    <link rel="alternate" href={alternateUrls.fr} hreflang="fr" />
    <link rel="canonical" href={alternateUrls[currentLocale as 'en' | 'fr']} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={alternateUrls[currentLocale as 'en' | 'fr']} />
    <meta property="og:locale" content={currentLocale === 'fr' ? 'fr_FR' : 'en_US'} />
    {currentLocale === 'fr' && <meta property="og:locale:alternate" content="en_US" />}
    {currentLocale === 'en' && <meta property="og:locale:alternate" content="fr_FR" />}
  </head>
  <body class="min-h-screen bg-[#ffffff] text-[#111827]">
    <Navigation items={navigationItems} />
    <div class="fixed top-4 right-4 z-50">
      <LanguageSwitcher />
    </div>
    <Container>
      <slot />
    </Container>
  </body>
</html>

<style is:global>
  /* Core layout custom properties */
  :root {
    --layout-width: clamp(var(--min-container), 90vw, var(--max-container));
  }

  /* Add styles for when mobile menu is open */
  body.menu-open {
    overflow: hidden;
  }
</style>