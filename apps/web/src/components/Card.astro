---
type Variant = 'default' | 'primary' | 'secondary' | 'accent';

interface Props {
  variant?: Variant;
  className?: string;
  interactive?: boolean;
  href?: string;
  ariaLabel?: string;
  pressed?: boolean;
  selected?: boolean;
  disabled?: boolean;
}

const { 
  variant = 'default',
  className = '',
  interactive = false,
  href,
  ariaLabel,
  pressed,
  selected,
  disabled
} = Astro.props;

const variantClasses = {
  'default': 'bg-[var(--color-white)] text-[#111827]',
  'primary': 'bg-[var(--color-green)] text-[#111827]',
  'secondary': 'bg-[var(--color-blue-dark)] text-white',
  'accent': 'bg-[var(--color-orange-dark)] text-white'
};

const baseClasses = `
  card
  relative
  p-6
  border-[var(--border-width-thick)]
  border-[var(--color-black)]
  rounded-[var(--radius-md)]
  shadow-[var(--shadow-sm)]
  transition-transform
  duration-[var(--animation-fast)]
  ease-[var(--ease-out)]
  overflow-hidden
  touch-action-manipulation
`;

const interactiveClasses = interactive || href ? `
  cursor-pointer
  @media(hover: hover) {
    hover:transform
    hover:-translate-y-2
    hover:shadow-brutalist-md
  }
  @media(hover: none) {
    active:transform
    active:scale-98
  }
  focus:outline-none
  focus-visible:ring-4
  focus-visible:ring-brand-blue
  focus-visible:ring-opacity-50
` : '';

const finalClasses = [
  baseClasses,
  variantClasses[variant],
  interactiveClasses,
  className,
  disabled ? 'opacity-50 cursor-not-allowed' : ''
].filter(Boolean).join(' ');
---

{href ? (
  <a 
    class={finalClasses}
    href={href}
    aria-label={ariaLabel}
    aria-disabled={disabled ? 'true' : null}
    aria-pressed={pressed ? 'true' : null}
    aria-selected={selected ? 'true' : null}
    tabindex={disabled ? -1 : 0}
  >
    <slot />
    {interactive && <div class="card-overlay" aria-hidden="true" />}
  </a>
) : interactive ? (
  <button 
    class={finalClasses}
    type="button"
    aria-label={ariaLabel}
    aria-disabled={disabled ? 'true' : null}
    aria-pressed={pressed ? 'true' : null}
    aria-selected={selected ? 'true' : null}
    tabindex={disabled ? -1 : 0}
    disabled={disabled}
  >
    <slot />
    <div class="card-overlay" aria-hidden="true" />
  </button>
) : (
  <div 
    class={finalClasses}
    aria-label={ariaLabel}
    aria-disabled={disabled ? 'true' : null}
    aria-pressed={pressed ? 'true' : null}
    aria-selected={selected ? 'true' : null}
  >
    <slot />
  </div>
)}

<script>
  // Add keyboard interaction support
  const cards = document.querySelectorAll<HTMLElement>('.card[role="button"]');
  cards.forEach(card => {
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        if (card instanceof HTMLElement) {
          card.click();
        }
      }
    });
  });
</script>

<style>
  .card {
    isolation: isolate;
    display: block;
    text-decoration: none;
  }

  .card-overlay {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.1);
    border-radius: var(--radius-md);
    opacity: 0;
    transition: opacity var(--animation-fast) var(--ease-out);
    pointer-events: none;
    z-index: 1;
  }

  .card:hover .card-overlay {
    opacity: 1;
  }

  .card:hover {
    text-decoration: none;
  }

  /* Improved focus styles */
  .card:focus-visible {
    outline: none;
    box-shadow: var(--shadow-md), 0 0 0 4px var(--color-blue-dark);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .card {
      transition: none;
    }
    
    .card-overlay {
      transition: none;
    }
  }
</style>
