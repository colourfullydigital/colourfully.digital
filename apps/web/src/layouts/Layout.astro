---
import '../styles/global.css';
import Container from '../components/layout/Container.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Colourfully Digital - Creative web development and design" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
  </head>
  <body class="min-h-screen bg-background text-text-primary">
    <Container>
      <slot />
    </Container>
  </body>
</html>

<style is:global>
  /* Core layout custom properties */
  :root {
    --layout-width: clamp(var(--min-container), 90vw, var(--max-container));
    --layout-gutter: var(--space-s-l, clamp(1.125rem, 0.6467rem + 2.3913vw, 2.5rem));
  }

  /* Base layout styles */
  html {
    scroll-behavior: smooth;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex-grow: 1;
  }
</style>
