---
interface Props {
  title: string;
  subtitle: string;
  primaryCTA: {
    text: string;
    href: string;
  };
  secondaryCTA?: {
    text: string;
    href: string;
  };
}

const { title, subtitle, primaryCTA, secondaryCTA } = Astro.props;
---

<section class="hero relative py-16 lg:py-24" role="banner" aria-labelledby="hero-title">
  <!-- Geometric Shapes -->
  <div class="shapes-container absolute inset-0 left-0 right-0 w-screen" aria-hidden="true">
    <div class="geometric-shape shape-1" role="presentation" />
    <div class="geometric-shape shape-2" role="presentation" />
    <div class="geometric-shape shape-3" role="presentation" />
    <div class="geometric-shape shape-4" role="presentation" />
  </div>

  <div class="container relative z-10 mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl">
      <h1 id="hero-title" class="gradient-text mb-6 text-5xl font-black leading-tight tracking-tight md:text-6xl lg:text-7xl">
        {title}
      </h1>
      
      <p class="mb-8 max-w-2xl text-lg text-text-secondary md:text-xl">
        {subtitle}
      </p>
      
      <div class="flex flex-wrap gap-4" role="group" aria-label="Hero call to action">
        <a
          href={primaryCTA.href}
          class="button button-primary inline-flex items-center"
          role="button"
          aria-label={primaryCTA.text}
        >
          {primaryCTA.text}
          <svg 
            class="ml-2 h-5 w-5" 
            viewBox="0 0 20 20" 
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path 
              fill-rule="evenodd" 
              d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" 
              clip-rule="evenodd" 
            />
          </svg>
        </a>
        
        {secondaryCTA && (
          <a
            href={secondaryCTA.href}
            class="button button-secondary inline-flex items-center"
            role="button"
            aria-label={secondaryCTA.text}
          >
            {secondaryCTA.text}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-white);
    min-height: calc(90vh - 4rem);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .shapes-container {
    position: absolute;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
    pointer-events: none;
  }

  .geometric-shape {
    position: absolute;
    border: var(--border-width-thick) solid var(--color-black);
    box-shadow: var(--shadow-md);
    opacity: 1;
  }

  .shape-1 {
    top: -5%;
    right: 10%;
    width: 150px;
    height: 150px;
    border-radius: var(--radius-md);
    transform: rotate(15deg);
    animation: float 8s ease-in-out infinite;
    background-color: var(--color-pink, #FF90B3);
  }

  .shape-2 {
    bottom: 10%;
    left: -5%;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    animation: float 10s ease-in-out infinite;
    background-color: var(--color-blue);
  }

  .shape-3 {
    top: 40%;
    right: -5%;
    width: 100px;
    height: 100px;
    clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
    animation: float 9s ease-in-out infinite;
    background-color: var(--color-green);
  }

  .shape-4 {
    bottom: 15%;
    right: 15%;
    width: 120px;
    height: 120px;
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
    animation: float 11s ease-in-out infinite;
    background-color: var(--color-yellow);
  }

  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--color-blue) 0%,
      var(--color-green) 50%,
      var(--color-orange) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .geometric-shape {
      animation: none;
    }
  }
</style>
