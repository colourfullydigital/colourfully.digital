---
import { useLanguage } from '../contexts/LanguageContext';

interface Props {
  class?: string;
}
---

<div class={`language-switcher ${Astro.props.class || ''}`}>
  <button
    class="lang-btn"
    data-current-lang="en"
    aria-label="Switch to English"
  >
    EN
  </button>
  <span class="separator">/</span>
  <button
    class="lang-btn"
    data-current-lang="fr"
    aria-label="Switch to French"
  >
    FR
  </button>
</div>

<style>
  .language-switcher {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: bold;
  }

  .lang-btn {
    padding: var(--touch-padding-base);
    min-height: var(--touch-target-size);
    min-width: var(--touch-target-size);
    cursor: pointer;
    border: none;
    background: none;
    color: inherit;
    opacity: 0.7;
    transition: opacity 0.2s, transform 0.2s;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .lang-btn[data-active="true"] {
    opacity: 1;
    text-decoration: underline;
    pointer-events: none;
  }

  /* Hover styles for non-touch devices */
  @media (hover: hover) {
    .lang-btn:hover {
      opacity: 1;
    }
  }

  /* Touch-specific styles */
  @media (hover: none) {
    .lang-btn:active {
      transform: scale(0.95);
      opacity: 1;
    }
    
    /* Increase spacing for touch targets */
    .language-switcher {
      gap: var(--touch-target-spacing);
    }
  }

  .separator {
    opacity: 0.5;
    padding: 0 var(--touch-target-spacing);
  }
</style>

<script>
  function initLanguageSwitcher() {
    const currentPath = window.location.pathname;
    const currentLang = currentPath.split('/')[1] || 'en';
    
    const buttons = document.querySelectorAll('.lang-btn');
    buttons.forEach(btn => {
      const lang = btn.getAttribute('data-current-lang');
      if (lang === currentLang) {
        btn.setAttribute('data-active', 'true');
      }
      
      btn.addEventListener('click', () => {
        const targetLang = btn.getAttribute('data-current-lang');
        if (targetLang && targetLang !== currentLang) {
          // Update the URL path to switch language
          const newPath = currentPath.replace(`/${currentLang}`, `/${targetLang}`);
          window.location.href = newPath;
        }
      });
    });
  }

  // Initialize when the DOM is loaded
  document.addEventListener('DOMContentLoaded', initLanguageSwitcher);
</script>
