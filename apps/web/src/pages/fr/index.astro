---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Card from '../../components/Card.astro';
import { createTranslator } from '../../i18n';
import content from '../../i18n/content.json';
import nav from '../../i18n/nav.json';

const locale = 'fr';
const t = createTranslator({ ...content, ...nav }, locale);
---

<Layout title={t('welcome.title')}>
  <Hero
    title={t('welcome.title')}
    subtitle={t('welcome.subtitle')}
    primaryCTA={{
      text: t('nav.startProject'),
      href: "/fr/contact"
    }}
    secondaryCTA={{
      text: t('nav.viewWork'),
      href: "/fr/portfolio"
    }}
  />

  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-4">{t('components.title')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Button showcase -->
      <div class="brutalist-box">
        <h3 class="text-xl font-bold mb-3">{t('components.buttons')}</h3>
        <div class="flex flex-wrap gap-4">
          <button class="button">{t('components.defaultButton')}</button>
          <button class="button button-primary">{t('components.primary')}</button>
          <button class="button button-secondary">{t('components.secondary')}</button>
          <button class="button button-accent">{t('components.accent')}</button>
        </div>
      </div>

      <!-- Card Components -->
      <div class="space-y-6">
        <h3 class="text-xl font-bold mb-3">{t('components.cards.title')}</h3>
        <Card>
          <h4 class="font-bold mb-2">{t('components.cards.default.title')}</h4>
          <p>{t('components.cards.default.description')}</p>
        </Card>
        
        <Card variant="primary" interactive href="#" ariaLabel={t('components.cards.primary.ariaLabel')}>
          <h4 class="font-bold mb-2">{t('components.cards.primary.title')}</h4>
          <p>{t('components.cards.primary.description')}</p>
        </Card>
        
        <Card variant="secondary">
          <h4 class="font-bold mb-2">{t('components.cards.secondary.title')}</h4>
          <p>{t('components.cards.secondary.description')}</p>
        </Card>
        
        <Card variant="accent" interactive>
          <h4 class="font-bold mb-2">{t('components.cards.accent.title')}</h4>
          <p>{t('components.cards.accent.description')}</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-4">{t('components.colors.title')}</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="p-6 bg-brand-green border-brutalist rounded-brutalist-md shadow-brutalist-sm">{t('components.colors.green')}</div>
      <div class="p-6 bg-brand-orange border-brutalist rounded-brutalist-md shadow-brutalist-sm text-white">{t('components.colors.orange')}</div>
      <div class="p-6 bg-brand-yellow border-brutalist rounded-brutalist-md shadow-brutalist-sm">{t('components.colors.yellow')}</div>
      <div class="p-6 bg-brand-blue border-brutalist rounded-brutalist-md shadow-brutalist-sm text-white">{t('components.colors.blue')}</div>
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-bold mb-4">{t('components.utilities.title')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="p-6 bg-gray-100 rounded-md">
        <h3 class="text-xl font-bold mb-3">{t('components.utilities.typography.title')}</h3>
        <p class="text-xs mb-1">{t('components.utilities.typography.sizes.xs')}</p>
        <p class="text-sm mb-1">{t('components.utilities.typography.sizes.sm')}</p>
        <p class="text-base mb-1">{t('components.utilities.typography.sizes.base')}</p>
        <p class="text-lg mb-1">{t('components.utilities.typography.sizes.lg')}</p>
        <p class="text-xl mb-1">{t('components.utilities.typography.sizes.xl')}</p>
        <p class="text-2xl mb-1">{t('components.utilities.typography.sizes.2xl')}</p>
      </div>
      <div class="p-6 bg-gray-100 rounded-md">
        <h3 class="text-xl font-bold mb-3">{t('components.utilities.spacing.title')}</h3>
        <div class="flex gap-2 flex-wrap">
          <div class="p-1 bg-brand-blue-light border">p-1</div>
          <div class="p-2 bg-brand-blue-light border">p-2</div>
          <div class="p-4 bg-brand-blue-light border">p-4</div>
          <div class="p-6 bg-brand-blue-light border">p-6</div>
        </div>
      </div>
    </div>
  </section>
</Layout>
