---
import LanguageSwitcher from '../LanguageSwitcher.astro';
import { createTranslator } from '../../i18n';
import nav from '../../i18n/nav.json';

interface Props {
  items: {
    label: string;
    href: string;
    children?: { label: string; href: string; }[];
  }[];
}

const { items } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
const currentLocale = pathname.split('/')[1] || 'en';
const t = createTranslator(nav, currentLocale);
---

<nav class="nav-container" aria-label={t('nav.main')}>
  <!-- Desktop Navigation -->
  <div class="nav-desktop">
    <a href="/" class="logo" aria-label="Colourfully Digital Home">
      <img src="/logo.png" alt="" width="40" height="40" />
    </a>
    <ul class="nav-list" role="menubar" aria-label={t('nav.main')}>
      {
        items.map((item) => {
          const isActive = pathname === item.href;
          const hasDropdown = !!item.children;
          
          return (
            <li 
              class:list={[
                "nav-item",
                { "has-dropdown": hasDropdown, "is-active": isActive }
              ]}
              role="none"
            >
              {
                hasDropdown ? (
                  <>
                    <button 
                      class="nav-button" 
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={`dropdown-${item.label}`}
                      role="menuitem"
                      data-dropdown-trigger
                    >
                      {item.label}
                      <span class="arrow" aria-hidden="true">▾</span>
                    </button>
                    <ul 
                      id={`dropdown-${item.label}`}
                      class="dropdown" 
                      role="menu" 
                      aria-label={`${item.label} submenu`}
                    >
                      {
                        item.children?.map((child) => (
                          <li role="none">
                            <a 
                              href={child.href}
                              class:list={[
                                "dropdown-item",
                                { "is-active": pathname === child.href }
                              ]}
                              role="menuitem"
                              aria-current={pathname === child.href ? "page" : undefined}
                            >
                              {child.label}
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </>
                ) : (
                  <a 
                    href={item.href}
                    class:list={[
                      "nav-link",
                      { "is-active": isActive }
                    ]}
                    role="menuitem"
                    aria-current={isActive ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                )
              }
            </li>
          );
        })
      }
    </ul>
    <div class="nav-lang-switcher">
      <LanguageSwitcher />
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="nav-mobile">
    <div class="nav-lang-switcher-mobile">
      <LanguageSwitcher />
    </div>
    <button 
      class="hamburger"
      aria-label={t('nav.menuButton')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-box">
        <span class="hamburger-inner"></span>
      </span>
    </button>

    <div 
      class="mobile-menu" 
      id="mobile-menu" 
      role="dialog"
      aria-label={t('nav.mobileMenu')}
      aria-modal="true"
      aria-hidden="true"
    >
      <nav>
        <ul class="mobile-nav-list" role="menu">
          {items.map(item => (
            <li role="none">
              {item.children ? (
                <>
                  <button 
                    class="mobile-nav-button" 
                    aria-expanded="false"
                    aria-controls={`mobile-dropdown-${item.label}`}
                    role="menuitem"
                  >
                    {item.label}
                    <span class="arrow" aria-hidden="true">▾</span>
                  </button>
                  <ul 
                    id={`mobile-dropdown-${item.label}`}
                    class="mobile-dropdown" 
                    role="menu" 
                    aria-label={`${item.label} submenu`}
                  >
                    {item.children.map(child => (
                      <li role="none">
                        <a 
                          href={child.href}
                          class:list={[
                            "mobile-nav-link",
                            { "is-active": pathname === child.href }
                          ]}
                          role="menuitem"
                          aria-current={pathname === child.href ? "page" : undefined}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a 
                  href={item.href}
                  class:list={[
                    "mobile-nav-link",
                    { "is-active": pathname === item.href }
                  ]}
                  role="menuitem"
                  aria-current={pathname === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</nav>
</nav>
<style>
  .nav-lang-switcher {
    display: flex;
    align-items: center;
    margin-left: auto;
    color: var(--color-text-primary);
  }
  .nav-lang-switcher-mobile {
    margin-left: 0;
    margin-top: var(--space-4);
    justify-content: flex-end;
    display: flex;
  }
  .nav-container {
    position: relative;
    z-index: 50;
    width: 100%;
    background-color: var(--color-surface);
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border-bottom: var(--border-width-thick) solid var(--color-black);
  }

  @media (max-width: 767px) {
    .nav-desktop {
      display: none;
    }
  }

  .nav-list {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-item {
    position: relative;
  }

  .nav-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    background: none;
    border: none;
    cursor: pointer;
    min-height: 44px;
    min-width: 44px;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) {
    .nav-button:hover {
      background-color: var(--color-surface-variant);
      border-radius: var(--radius-sm);
    }
  }

  @media (hover: none) {
    .nav-button:active {
      transform: scale(0.98);
    }
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 51;
    min-width: 200px;
    margin-top: var(--space-2);
    padding: var(--space-2);
    background-color: var(--color-surface);
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  @media (hover: hover) {
    .nav-item:hover .dropdown {
      display: block;
    }
  }
  
  .nav-button[aria-expanded="true"] + .dropdown {
    display: block;
  }

  .dropdown-item {
    display: block;
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    min-height: 44px;
    display: flex;
    align-items: center;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) {
    .dropdown-item:hover {
      background-color: var(--color-surface-variant);
    }
  }

  @media (hover: none) {
    .dropdown-item:active {
      background-color: var(--color-surface-variant);
      transform: scale(0.98);
    }
  }

  .logo {
    display: flex;
    align-items: center;
    margin-right: var(--space-4);
    flex-shrink: 0;
  }

  .logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .nav-desktop {
    position: relative;
    display: flex;
    align-items: center;
    padding: var(--space-4);
    width: 100%;
    gap: var(--space-4);
  }
  .nav-list {
    display: flex;
    flex: 1 1 0%;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .nav-lang-switcher {
    margin-left: auto;
    display: flex;
    align-items: center;
    color: var(--color-text-primary);
    flex-shrink: 0;
  }

  .nav-list {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link,
  .nav-button {
    display: inline-flex;
    align-items: center;
    padding: var(--touch-padding-base);
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
    min-height: var(--touch-target-size);
    min-width: var(--touch-target-size);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: transform var(--animation-fast) var(--ease-out),
                box-shadow var(--animation-fast) var(--ease-out);
  }

  /* Hover styles only for devices with hover capability */
  @media (hover: hover) {
    .nav-link:hover,
    .nav-button:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }
  }

  /* Touch-specific styles */
  @media (hover: none) {
    .nav-link:active,
    .nav-button:active {
      transform: scale(0.98);
    }

    /* Make dropdown trigger more prominent on touch */
    .nav-button[aria-haspopup="true"]::after {
      content: "▾";
      margin-left: var(--space-2);
      font-size: 1.2em;
    }

    /* Show dropdowns on click instead of hover for touch devices */
    .nav-item:hover .dropdown {
      display: none;
    }

    .nav-button[aria-expanded="true"] + .dropdown {
      display: block;
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }

  /* Increase dropdown target sizes for touch */
  .dropdown-item {
    display: block;
    padding: var(--touch-padding-base);
    min-height: var(--touch-target-size);
    color: var(--color-text-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  /* Mobile Navigation Styles */
  .nav-mobile {
    display: block;
    padding: var(--space-4);
  }

  .hamburger {
    position: relative;
    padding: var(--space-2);
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
  }

  .hamburger-box {
    position: relative;
    display: inline-block;
    width: 24px;
    height: 20px;
  }

  .hamburger-inner {
    position: absolute;
    width: 24px;
    height: 3px;
    background-color: var(--color-black);
    transition: transform var(--animation-fast) var(--ease-out);
  }

  .hamburger-inner::before,
  .hamburger-inner::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 3px;
    background-color: var(--color-black);
    transition: transform var(--animation-fast) var(--ease-out);
  }

  .hamburger-inner::before {
    top: -8px;
  }

  .hamburger-inner::after {
    bottom: -8px;
  }

  .hamburger[aria-expanded="true"] .hamburger-inner {
    transform: rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-inner::before {
    transform: rotate(-45deg) translate(5.5px, -5.5px);
  }

  .hamburger[aria-expanded="true"] .hamburger-inner::after {
    transform: rotate(-45deg) translate(5.5px, 5.5px);
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    padding: var(--space-6);
    background-color: var(--color-surface);
    transform: translateX(-100%);
    transition: transform var(--animation-normal) var(--ease-out);
  }

  .mobile-menu[aria-hidden="false"] {
    transform: translateX(0);
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-link,
  .mobile-nav-button {
    display: block;
    width: 100%;
    padding: var(--space-4);
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-dropdown {
    display: none;
    padding-left: var(--space-4);
  }

  .mobile-nav-button[aria-expanded="true"] + .mobile-dropdown {
    display: block;
  }

  /* Media Queries */
  @media (min-width: 768px) {
    .nav-mobile {
      display: none;
    }

    .nav-desktop {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link,
    .nav-button,
    .hamburger-inner,
    .hamburger-inner::before,
    .hamburger-inner::after,
    .mobile-menu {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  // Enhance keyboard navigation
  document.addEventListener('keydown', (e) => {
    // Close dropdowns and mobile menu on Escape
    if (e.key === 'Escape') {
      const expandedButtons = document.querySelectorAll('[aria-expanded="true"]');
      expandedButtons.forEach(button => {
        button.setAttribute('aria-expanded', 'false');
        const controlledElement = document.getElementById(button.getAttribute('aria-controls') || '');
        if (controlledElement) {
          controlledElement.setAttribute('aria-hidden', 'true');
        }
      });
      document.body.classList.remove('menu-open');
    }
  });

  // Update dropdown behavior for touch devices
  function initTouchNavigation() {
    const dropdownButtons = document.querySelectorAll('[data-dropdown-trigger]');
    const isTouchDevice = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

    dropdownButtons.forEach(button => {
      if (isTouchDevice) {
        button.addEventListener('touchend', (e) => {
          e.preventDefault();
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          
          // Close other dropdowns
          dropdownButtons.forEach(otherButton => {
            if (otherButton !== button) {
              otherButton.setAttribute('aria-expanded', 'false');
              const otherId = otherButton.getAttribute('aria-controls');
              if (otherId) {
                const otherDropdown = document.getElementById(otherId);
                otherDropdown?.setAttribute('aria-hidden', 'true');
              }
            }
          });

          // Toggle current dropdown
          button.setAttribute('aria-expanded', (!isExpanded).toString());
          const controlId = button.getAttribute('aria-controls');
          if (controlId) {
            const dropdown = document.getElementById(controlId);
            dropdown?.setAttribute('aria-hidden', isExpanded.toString());
          }
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initTouchNavigation);

  // Handle mobile menu
  const hamburger = document.querySelector('.hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  
  hamburger?.addEventListener('click', () => {
    const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenu?.setAttribute('aria-hidden', isExpanded.toString());
    document.body.classList.toggle('menu-open');
    
    // Manage focus
    if (!isExpanded) {
      const firstFocusable = mobileMenu?.querySelector('[role="menuitem"]');
      if (firstFocusable instanceof HTMLElement) {
        firstFocusable.focus();
      }
    }
  });
</script>