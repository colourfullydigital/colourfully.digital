---
import LanguageSwitcher from '../LanguageSwitcher.astro';
import { createTranslator } from '../../i18n';
import nav from '../../i18n/nav.json';

interface Props {
  items: {
    label: string;
    href: string;
    children?: { label: string; href: string; }[];
  }[];
}

const { items } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
const currentLocale = pathname.split('/')[1] || 'en';
const t = createTranslator(nav, currentLocale);
---

<nav class="nav-container" aria-label={t('nav.main')}>
  <!-- Desktop Navigation -->
  <div class="nav-desktop">
    <a href="/" class="logo" aria-label="Colourfully Digital Home">
      <img src="/logo.png" alt="" width="40" height="40" />
    </a>
    <ul class="nav-list" role="menubar" aria-label={t('nav.main')}>
      {
        items.map((item) => {
          const isActive = pathname === item.href;
          const hasDropdown = !!item.children;
          
          return (
            <li 
              class:list={[
                "nav-item",
                { "has-dropdown": hasDropdown, "is-active": isActive }
              ]}
              role="none"
            >
              {
                hasDropdown ? (
                  <>
                    <button 
                      class="nav-button" 
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={`dropdown-${item.label}`}
                      role="menuitem"
                      data-dropdown-trigger
                    >
                      {item.label}
                      <span class="arrow" aria-hidden="true">
                        <svg width="12" height="6" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    </button>
                    <ul 
                      id={`dropdown-${item.label}`}
                      class="dropdown" 
                      role="menu" 
                      aria-label={`${item.label} submenu`}
                    >
                      {
                        item.children?.map((child) => (
                          <li role="none">
                            <a 
                              href={child.href}
                              class:list={[
                                "dropdown-item",
                                { "is-active": pathname === child.href }
                              ]}
                              role="menuitem"
                              aria-current={pathname === child.href ? "page" : undefined}
                            >
                              {child.label}
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </>
                ) : (
                  <a 
                    href={item.href}
                    class:list={[
                      "nav-link",
                      { "is-active": isActive }
                    ]}
                    role="menuitem"
                    aria-current={isActive ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                )
              }
            </li>
          );
        })
      }
    </ul>
    <div class="nav-lang-switcher">
      <LanguageSwitcher />
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="nav-mobile">
    <div class="nav-mobile-header">
      <a href="/" class="logo-mobile" aria-label="Colourfully Digital Home">
        <img src="/logo.png" alt="" width="36" height="36" />
      </a>
      <button 
        class="hamburger"
        aria-label={t('nav.menuButton')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-hamburger
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 6H21" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <path d="M3 12H21" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <path d="M3 18H21" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div 
      class="mobile-menu" 
      id="mobile-menu" 
      role="dialog"
      aria-label={t('nav.mobileMenu')}
      aria-modal="true"
      aria-hidden="true"
    >
      <nav class="mobile-nav">
        <ul class="mobile-nav-list" role="menu">
          {items.map(item => (
            <li class="mobile-nav-item" role="none">
              {item.children ? (
                <>
                  <button 
                    class="mobile-nav-button" 
                    aria-expanded="false"
                    aria-controls={`mobile-dropdown-${item.label}`}
                    role="menuitem"
                    data-mobile-dropdown-toggle
                  >
                    <span>{item.label}</span>
                    <span class="mobile-arrow" aria-hidden="true">
                      <svg width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </button>
                  <div 
                    id={`mobile-dropdown-${item.label}`}
                    class="mobile-dropdown" 
                    hidden
                  >
                    <ul role="menu" aria-label={`${item.label} submenu`}>
                      {item.children.map(child => (
                        <li role="none">
                          <a 
                            href={child.href}
                            class:list={[
                              "mobile-dropdown-link",
                              { "is-active": pathname === child.href }
                            ]}
                            role="menuitem"
                            aria-current={pathname === child.href ? "page" : undefined}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </>
              ) : (
                <a 
                  href={item.href}
                  class:list={[
                    "mobile-nav-link",
                    { "is-active": pathname === item.href }
                  ]}
                  role="menuitem"
                  aria-current={pathname === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ul>
        <div class="nav-lang-switcher-mobile">
          <LanguageSwitcher />
        </div>
      </nav>
    </div>
  </div>
</nav>
<style>
  .nav-lang-switcher {
    display: flex;
    align-items: center;
    margin-left: auto;
    color: var(--color-text-primary);
  }
  .nav-lang-switcher-mobile {
    margin-top: var(--space-8);
    display: flex;
    justify-content: center;
  }
  .nav-container {
    position: relative;
    z-index: 50;
    width: 100%;
    background-color: var(--color-surface);
  }
  
  .nav-mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border-bottom: var(--border-width-thick) solid var(--color-black);
    background-color: var(--color-surface);
    position: relative;
    z-index: 49;
  }
  
  .logo-mobile {
    display: flex;
    align-items: center;
  }

  .nav-desktop {
    padding: var(--space-4);
    border-bottom: var(--border-width-thick) solid var(--color-black);
  }

  /* Base configuration for navigation modes */
  .nav-desktop {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .nav-mobile {
    display: none; /* Hidden by default */
  }
  
  /* Media queries for responsive navigation */
  @media screen and (max-width: 767px) {
    .nav-desktop {
      display: none !important; /* Force hide on mobile */
    }
    
    .nav-mobile {
      display: block !important; /* Force show on mobile */
    }
  }
  
  /* Make sure we're not showing mobile nav on larger screens */
  @media screen and (min-width: 768px) {
    .nav-desktop {
      display: flex !important; /* Force show on desktop */
    }
    
    .nav-mobile {
      display: none !important; /* Force hide on desktop */
    }
  }

  .nav-list {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-item {
    position: relative;
  }

  .nav-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    background: none;
    border: none;
    cursor: pointer;
    min-height: 44px;
    min-width: 44px;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) {
    .nav-button:hover {
      background-color: var(--color-surface-variant);
      border-radius: var(--radius-sm);
    }
  }

  @media (hover: none) {
    .nav-button:active {
      transform: scale(0.98);
    }
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 51;
    min-width: 200px;
    margin-top: var(--space-2);
    padding: var(--space-2);
    background-color: var(--color-surface);
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  @media (hover: hover) {
    .nav-item:hover .dropdown {
      display: block;
    }
  }
  
  .nav-button[aria-expanded="true"] + .dropdown {
    display: block;
  }

  .dropdown-item {
    display: block;
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    min-height: 44px;
    display: flex;
    align-items: center;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) {
    .dropdown-item:hover {
      background-color: var(--color-surface-variant);
    }
  }

  @media (hover: none) {
    .dropdown-item:active {
      background-color: var(--color-surface-variant);
      transform: scale(0.98);
    }
  }

  .logo {
    display: flex;
    align-items: center;
    margin-right: var(--space-4);
    flex-shrink: 0;
  }

  .logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .nav-desktop {
    position: relative;
    display: flex;
    align-items: center;
    padding: var(--space-4);
    width: 100%;
    gap: var(--space-4);
  }
  .nav-list {
    display: flex;
    flex: 1 1 0%;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .nav-lang-switcher {
    margin-left: auto;
    display: flex;
    align-items: center;
    color: var(--color-text-primary);
    flex-shrink: 0;
  }

  .nav-list {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link,
  .nav-button {
    display: inline-flex;
    align-items: center;
    padding: var(--touch-padding-base);
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
    min-height: var(--touch-target-size);
    min-width: var(--touch-target-size);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: transform var(--animation-fast) var(--ease-out),
                box-shadow var(--animation-fast) var(--ease-out);
  }

  /* Hover styles only for devices with hover capability */
  @media (hover: hover) {
    .nav-link:hover,
    .nav-button:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }
  }

  /* Touch-specific styles */
  @media (hover: none) {
    .nav-link:active,
    .nav-button:active {
      transform: scale(0.98);
    }

    /* Remove duplicate dropdown arrow for touch devices */
    .nav-button .arrow {
      margin-left: var(--space-2);
    }

    /* Show dropdowns on click instead of hover for touch devices */
    .nav-item:hover .dropdown {
      display: none;
    }

    .nav-button[aria-expanded="true"] + .dropdown {
      display: block;
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }

  /* Increase dropdown target sizes for touch */
  .dropdown-item {
    display: block;
    padding: var(--touch-padding-base);
    min-height: var(--touch-target-size);
    color: var(--color-text-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  /* Mobile Navigation Styles */
  .hamburger {
    position: relative;
    padding: var(--space-3);
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: var(--radius-md);
    background-color: var(--color-black); /* Dark background for white icon */
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .hamburger:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  
  .hamburger:active {
    transform: translateY(0);
    box-shadow: var(--shadow-sm);
  }

  /* SVG-based hamburger icon - no longer need the inner/before/after elements */
  .hamburger svg path {
    transition: transform var(--animation-fast) var(--ease-out), 
               opacity var(--animation-fast) var(--ease-out);
  }

  /* Animation for hamburger to X */
  .hamburger[aria-expanded="true"] svg path:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] svg path:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] svg path:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu uses the animated hamburger button for closing */
  
  .nav-lang-switcher-mobile {
    margin-top: auto;
    padding-top: var(--space-6);
    display: flex;
    justify-content: center;
  }
  
  .nav-link.is-active,
  .dropdown-item.is-active {
    background-color: var(--color-surface-variant);
    font-weight: var(--font-weight-bold);
    border-color: var(--color-brand-blue);
  }
  
  .mobile-nav-link.is-active,
  .mobile-dropdown-link.is-active {
    background-color: var(--color-surface-variant);
    font-weight: var(--font-weight-bold);
    border-left: 3px solid var(--color-brand-blue);
  }
  
  /* Reduced motion considerations */

  /* Additional global styles */
  :global(body.menu-open) {
    overflow: hidden;
    position: fixed;
    width: 100%;
    height: 100%;
  }

  .arrow {
    display: inline-flex;
    margin-left: var(--space-2);
    transition: transform var(--animation-fast) var(--ease-out);
  }

  .nav-button[aria-expanded="true"] .arrow {
    transform: rotate(180deg);
  }

  /* Mobile-specific menu styles */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--color-surface);
    transform: translateX(-100%);
    transition: transform var(--animation-normal) var(--ease-out);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu.is-open,
  .mobile-menu[aria-hidden="false"] {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-header {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
</style>

<script>
  // Enhance keyboard navigation
  document.addEventListener('keydown', (e) => {
    // Close dropdowns and mobile menu on Escape
    if (e.key === 'Escape') {
      const expandedButtons = document.querySelectorAll('[aria-expanded="true"]');
      expandedButtons.forEach(button => {
        button.setAttribute('aria-expanded', 'false');
        const controlledElement = document.getElementById(button.getAttribute('aria-controls') || '');
        if (controlledElement) {
          controlledElement.setAttribute('aria-hidden', 'true');
        }
      });
      document.body.classList.remove('menu-open');
    }
  });

  // Update dropdown behavior for all devices
  function initDesktopNavigation() {
    const dropdownButtons = document.querySelectorAll('[data-dropdown-trigger]');
    const isTouchDevice = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

    dropdownButtons.forEach(button => {
      // Function to toggle dropdown
      function toggleDropdown(e: Event) {
        e.preventDefault();
        e.stopPropagation();
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        // Close other dropdowns
        dropdownButtons.forEach(otherButton => {
          if (otherButton !== button) {
            otherButton.setAttribute('aria-expanded', 'false');
            const otherId = otherButton.getAttribute('aria-controls');
            if (otherId) {
              const otherDropdown = document.getElementById(otherId);
              otherDropdown?.setAttribute('aria-hidden', 'true');
            }
          }
        });

        // Toggle current dropdown
        button.setAttribute('aria-expanded', (!isExpanded).toString());
        const controlId = button.getAttribute('aria-controls');
        if (controlId) {
          const dropdown = document.getElementById(controlId);
          if (dropdown) {
            dropdown.setAttribute('aria-hidden', isExpanded.toString());
            
            // If opening dropdown, focus the first item
            if (!isExpanded) {
              const firstItem = dropdown.querySelector('a[role="menuitem"]') as HTMLElement;
              if (firstItem) setTimeout(() => firstItem.focus(), 100);
            }
          }
        }
      }
      
      // Touch events for touch devices
      if (isTouchDevice) {
        button.addEventListener('touchend', toggleDropdown);
      }
      
      // Click event for all devices
      button.addEventListener('click', toggleDropdown);
      
      // Keyboard navigation
      button.addEventListener('keydown', (e) => {
        const kbEvent = e as KeyboardEvent;
        if (kbEvent.key === 'Enter' || kbEvent.key === ' ') {
          e.preventDefault();
          toggleDropdown(e);
        } else if (kbEvent.key === 'Escape') {
          e.preventDefault();
          button.setAttribute('aria-expanded', 'false');
          const controlId = button.getAttribute('aria-controls');
          if (controlId) {
            const dropdown = document.getElementById(controlId);
            dropdown?.setAttribute('aria-hidden', 'true');
          }
          (button as HTMLElement).focus();
        }
      });
    });
    
    // Close dropdowns when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      const expandedButtons = document.querySelectorAll('[data-dropdown-trigger][aria-expanded="true"]');
      
      expandedButtons.forEach(button => {
        const controlId = button.getAttribute('aria-controls');
        const dropdown = controlId ? document.getElementById(controlId) : null;
        
        // If click is outside of button and dropdown
        if (!button.contains(target) && (!dropdown || !dropdown.contains(target))) {
          button.setAttribute('aria-expanded', 'false');
          dropdown?.setAttribute('aria-hidden', 'true');
        }
      });
    });
  }

  // Initialize mobile navigation
  function initMobileNavigation() {
    const hamburger = document.querySelector('[data-hamburger]');
    const mobileMenu = document.getElementById('mobile-menu');
    
    console.log('Initializing Mobile Navigation:');
    console.log('Hamburger button:', hamburger);
    console.log('Mobile menu:', mobileMenu);
    
    const mobileDropdownToggles = document.querySelectorAll('[data-mobile-dropdown-toggle]');
    
    // Helper to get all focusable elements
    const getFocusableElements = (element: HTMLElement) => {
      const elements = element.querySelectorAll(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      );
      return Array.from(elements) as HTMLElement[];
    };

    // Open mobile menu
    function openMobileMenu() {
      if (!hamburger || !mobileMenu) return;
      
      document.body.classList.add('menu-open');
      hamburger.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
      mobileMenu.classList.add('is-open');
      
      // Focus the first focusable element in the menu
      const firstFocusable = getFocusableElements(mobileMenu as HTMLElement)[0];
      if (firstFocusable) {
        setTimeout(() => firstFocusable.focus(), 100);
      }
    }

    // Close mobile menu
    function closeMobileMenu() {
      if (!hamburger || !mobileMenu) return;
      
      document.body.classList.remove('menu-open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenu.classList.remove('is-open');
      
      // Close any open dropdowns
      mobileDropdownToggles.forEach(toggle => {
        toggle.setAttribute('aria-expanded', 'false');
        const dropdownId = toggle.getAttribute('aria-controls');
        if (dropdownId) {
          const dropdown = document.getElementById(dropdownId);
          dropdown?.setAttribute('hidden', '');
        }
      });
      
      // Return focus to hamburger
      if (hamburger instanceof HTMLElement) {
        hamburger.focus();
      }
    }

    // Toggle mobile menu
    hamburger?.addEventListener('click', () => {
      console.log('Hamburger clicked');
      const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        console.log('Closing mobile menu');
        closeMobileMenu();
      } else {
        console.log('Opening mobile menu');
        openMobileMenu();
      }
    });

    // Note: We don't need a separate close button handler as the hamburger button handles both open and close

    // Handle expandable dropdowns in mobile menu
    mobileDropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', (!isExpanded).toString());
        
        const dropdownId = toggle.getAttribute('aria-controls');
        if (dropdownId) {
          const dropdown = document.getElementById(dropdownId);
          if (isExpanded) {
            dropdown?.setAttribute('hidden', '');
          } else {
            dropdown?.removeAttribute('hidden');
          }
        }
      });
    });

    // Close menu on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu && mobileMenu.getAttribute('aria-hidden') === 'false') {
        closeMobileMenu();
      }
    });

    // Trap focus within mobile menu when open
    document.addEventListener('keydown', (e) => {
      if (!mobileMenu || mobileMenu.getAttribute('aria-hidden') === 'true' || e.key !== 'Tab') return;
      
      const focusableElements = getFocusableElements(mobileMenu);
      const firstElement = focusableElements[0] as HTMLElement;
      const lastElement = focusableElements[focusableElements.length - 1] as HTMLElement;
      
      // If shift+tab on first element, go to last element
      if (e.shiftKey && document.activeElement === firstElement) {
        e.preventDefault();
        lastElement.focus();
      }
      // If tab on last element, circle back to first element
      else if (!e.shiftKey && document.activeElement === lastElement) {
        e.preventDefault();
        firstElement.focus();
      }
    });

    // Prevent body scrolling when menu is open
    document.body.addEventListener('touchmove', (e) => {
      if (document.body.classList.contains('menu-open')) {
        e.preventDefault();
      }
    }, { passive: false });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initDesktopNavigation();
    initMobileNavigation();
  });
</script>