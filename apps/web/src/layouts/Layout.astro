---
import '../styles/global.css';
import Container from '../components/layout/Container.astro';
import Navigation from '../components/layout/Navigation.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const navigationItems = [
  { label: 'Home', href: '/' },
  { 
    label: 'Services', 
    href: '/services',
    children: [
      { label: 'Web Development', href: '/services/web-development' },
      { label: 'Design', href: '/services/design' },
      { label: 'Consulting', href: '/services/consulting' }
    ]
  },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Colourfully Digital - Creative web development and design" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
  </head>
  <body class="min-h-screen bg-[#ffffff] text-[#111827]">
    <Navigation items={navigationItems} />
    <Container>
      <slot />
    </Container>
  </body>
</html>

<style is:global>
  /* Core layout custom properties */
  :root {
    --layout-width: clamp(var(--min-container), 90vw, var(--max-container));
  }

  /* Add styles for when mobile menu is open */
  body.menu-open {
    overflow: hidden;
  }
</style>